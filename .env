# --- إعدادات منصة محجوب أونلاين السيادية ---

# 1. مفتاح الأمان (تأكد من بقائه سرياً لتأمين حسابك)
SECRET_KEY=Ali_Mahjoub_Sovereign_2026_Secure_Key

# 2. رابط قاعدة البيانات (Railway يوفره تلقائياً باسم DATABASE_URL)
# ملاحظة: سيقوم الكود الذي وضعناه في core/__init__.py بتصحيح الرابط آلياً إذا بدأ بـ postgres://
DATABASE_URL=postgresql://user:password@host:port/database

# 3. بورت التشغيل (تم الضبط على 8080 بناءً على طلبك)
PORT=8080

# 4. بيئة التشغيل (نضعها production عند الرفع الفعلي)
FLASK_ENV=production
FLASK_DEBUG=0
